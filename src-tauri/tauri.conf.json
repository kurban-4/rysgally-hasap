{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rysgally-hasap",
  "version": "0.1.0",
  "identifier": "com.annagurban.rysgally-hasap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:8000",
    "frontendDist": "http://localhost:8000" 
  },
  "app": {
    "windows": [
      {
        "title": "rysgally-hasap",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: http://127.0.0.1:8000; connect-src 'self' http://127.0.0.1:8000 tauri://localhost"
    }
  },
  "bundle": {
   "resources": [
  "resources/SirinNabat/**/*",
  "resources/SirinNabat/.env",
  "binaries/php.ini"
],
  "externalBin": [
    "binaries/php"
  ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}